ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# ---------------------------------------------------------------------------
# Reinforcement Learning layer (tabular Q-learning, shadow/advisory)
# ---------------------------------------------------------------------------
# RL_ENABLED   : turn the advisory layer on/off (true|false)
# RL_MODE      : shadow = recommend + learn only (does NOT change trades).
#                gate/control are reserved for future active use.
# RL_ALPHA     : learning rate
# RL_GAMMA     : discount factor (cross-day PDT coupling)
# RL_EPSILON   : exploration rate (decays toward RL_EPSILON_MIN)
RL_ENABLED=true
RL_MODE=shadow
RL_ALPHA=0.10
RL_GAMMA=0.50
RL_EPSILON=0.20
RL_EPSILON_DECAY=0.995
RL_EPSILON_MIN=0.02

# ---------------------------------------------------------------------------
# Market Fear & Greed sentiment module
# ---------------------------------------------------------------------------
# SENTIMENT_ENABLED        : master on/off switch for the sentiment filter
# SENTIMENT_CACHE_MINUTES  : how long to reuse a computed score before refresh
# SENTIMENT_USE_CNN        : fetch CNN's unofficial Fear & Greed index
# SENTIMENT_USE_CUSTOM     : compute our own score from market data (PRIMARY)
# SENTIMENT_PRIMARY_SOURCE : which score drives trade decisions (custom|cnn)
# SENTIMENT_MIN_COMPONENTS : min available components for a valid custom score
# SENTIMENT_CNN_URL        : (optional) override CNN endpoint
# SENTIMENT_CNN_TIMEOUT    : (optional) CNN request timeout, seconds
# SENTIMENT_HISTORY_DAYS   : (optional) days of daily history for the custom score
# SENTIMENT_MOMENTUM_WINDOW: (optional) SPY moving-average window (trading days)
# SENTIMENT_CACHE_FILE     : (optional) cache file path
SENTIMENT_ENABLED=true
SENTIMENT_CACHE_MINUTES=15
SENTIMENT_USE_CNN=true
SENTIMENT_USE_CUSTOM=true
SENTIMENT_PRIMARY_SOURCE=custom
SENTIMENT_MIN_COMPONENTS=3