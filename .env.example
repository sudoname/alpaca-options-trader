ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# ---------------------------------------------------------------------------
# Telegram trading bot (telegram_bot.py)
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN       : bot token from @BotFather
# TELEGRAM_CHAT_ID         : owner chat ID (always authorized)
# TELEGRAM_ALLOWED_CHAT_IDS: comma-separated list of additional chat IDs
#                            allowed to use the bot (e.g. to authorize other
#                            people). The owner TELEGRAM_CHAT_ID is always
#                            included. If both are empty, the bot is open to all.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ALLOWED_CHAT_IDS=

# ---------------------------------------------------------------------------
# Reinforcement Learning layer (tabular Q-learning, shadow/advisory)
# ---------------------------------------------------------------------------
# RL_ENABLED   : turn the advisory layer on/off (true|false)
# RL_MODE      : shadow = recommend + learn only (does NOT change trades).
#                gate/control are reserved for future active use.
# RL_ALPHA     : learning rate
# RL_GAMMA     : discount factor (cross-day PDT coupling)
# RL_EPSILON   : exploration rate (decays toward RL_EPSILON_MIN)
RL_ENABLED=true
RL_MODE=shadow
RL_ALPHA=0.10
RL_GAMMA=0.50
RL_EPSILON=0.20
RL_EPSILON_DECAY=0.995
RL_EPSILON_MIN=0.02

# Conservative veto-only gate (currently used by backtest_rl_gate.py only).
# The gate can turn a rule-chosen CALL/PUT into a SKIP, but never flips
# direction and never mutates the Q-table. A veto fires only when a state has
# enough history AND a materially negative learned value AND enough confidence.
# RL_GATE_MIN_VISITS    : min (state,action) visits before a veto is allowed
# RL_GATE_MAX_Q         : veto only when learned Q is at/below this (negative)
# RL_GATE_MIN_CONFIDENCE: confidence = min(1, visits/min_visits) required to veto
RL_GATE_MIN_VISITS=8
RL_GATE_MAX_Q=-0.10
RL_GATE_MIN_CONFIDENCE=0.75

# ---------------------------------------------------------------------------
# Market Fear & Greed sentiment module
# ---------------------------------------------------------------------------
# SENTIMENT_ENABLED        : master on/off switch for the sentiment filter
# SENTIMENT_CACHE_MINUTES  : how long to reuse a computed score before refresh
# SENTIMENT_USE_CNN        : fetch CNN's unofficial Fear & Greed index
# SENTIMENT_USE_CUSTOM     : compute our own score from market data (PRIMARY)
# SENTIMENT_PRIMARY_SOURCE : which score drives trade decisions (custom|cnn)
# SENTIMENT_MIN_COMPONENTS : min available components for a valid custom score
# SENTIMENT_CNN_URL        : (optional) override CNN endpoint
# SENTIMENT_CNN_TIMEOUT    : (optional) CNN request timeout, seconds
# SENTIMENT_HISTORY_DAYS   : (optional) days of daily history for the custom score
# SENTIMENT_MOMENTUM_WINDOW: (optional) SPY moving-average window (trading days)
# SENTIMENT_CACHE_FILE     : (optional) cache file path
SENTIMENT_ENABLED=true
SENTIMENT_CACHE_MINUTES=15
SENTIMENT_USE_CNN=true
SENTIMENT_USE_CUSTOM=true
SENTIMENT_PRIMARY_SOURCE=custom
SENTIMENT_MIN_COMPONENTS=3

# ---------------------------------------------------------------------------
# Stock screener (stock_screener.py) — Nasdaq Buy/Strong-Buy universe ranked
# with Alpaca price data (keeps the project's data source, no Yahoo Finance).
# ---------------------------------------------------------------------------
# NASDAQ_API_URL      : Nasdaq screener API URL (Buy/Strong-Buy universe)
# STOCK_MIN_PRICE     : skip stocks priced below this
# STOCK_MAX_PRICE     : skip stocks priced above this
# MAX_NUM_STOCKS      : max number of picks to return
# MOVED_DAYS          : lookback (trading days) for the movement/range metrics
# SCREEN_STRATEGY     : default ranking: moved | lowtomarket | lowtohigh
# SCREENER_ALPACA_FEED: Alpaca market-data feed for bars (iex|sip)
NASDAQ_API_URL=https://api.nasdaq.com/api/screener/stocks?tableonly=true&limit=100&marketcap=large|mid|small&recommendation=strong_buy|buy
STOCK_MIN_PRICE=20
STOCK_MAX_PRICE=100
MAX_NUM_STOCKS=20
MOVED_DAYS=5
SCREEN_STRATEGY=moved
SCREENER_ALPACA_FEED=iex