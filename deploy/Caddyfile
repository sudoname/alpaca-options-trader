# Caddy reverse proxy for the Oracle dashboard.
#
# Caddy auto-provisions and renews a Let's Encrypt TLS cert for the domain
# below, terminates HTTPS, enforces HTTP Basic Auth, and proxies to the Flask
# app on 127.0.0.1:8787 (which is NOT publicly reachable).
#
# Prerequisites:
#   1. DNS A record:  oracle.lasgidi.ng -> <droplet public IP>
#   2. Ports 80 and 443 open; keep 8787 bound to localhost only.
#   3. Generate the password hash (do NOT store a plaintext password here):
#        caddy hash-password --plaintext 'YOUR_PASSWORD'
#      then paste the resulting bcrypt hash into the basic_auth block below.
#
# Install:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy

oracle.lasgidi.ng {
	encode gzip

	basic_auth {
		# username  <bcrypt-hash-from-`caddy hash-password`>
		oracle $2a$14$REPLACE_WITH_BCRYPT_HASH
	}

	reverse_proxy 127.0.0.1:8787

	log {
		output file /var/log/caddy/oracle-dashboard.log
	}
}
